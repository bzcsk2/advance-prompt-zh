APP_NAME=agentic-rag-enterprise
APP_ENV=development
LOG_LEVEL=INFO

# Model provider
#   mock  = deterministic fake (no external service needed, default)
#   zen   = https://opencode.ai/zen/v1  (keyless)
#   kilo  = https://api.kilo.ai/api/gateway/v1  (keyless)
LLM_PROVIDER=mock
# Optional: override default model per provider
#   llm_model=
EMBEDDING_PROVIDER=mock

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Runtime limits
MAX_ITERATIONS=3
MAX_TOOL_CALLS=12
MAX_RETRIEVAL_TOP_K=8
